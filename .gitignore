# ─── Python ────────────────────────────────────────────────────────────
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ─── Virtual environments ──────────────────────────────────────────────
.venv/
venv/
env/

# ─── Secrets & local config ────────────────────────────────────────────
# .env holds real API keys / passwords — never commit it. The template
# (.env.example) IS committed so others know which variables to set.
.env
.env.*
!.env.example

# ─── Local data & runtime artifacts ────────────────────────────────────
*.db
*.sqlite3
storage/
.fastembed_cache/
.cache/
*.log

# ─── Uploaded / source documents (data, not code) ──────────────────────
*.pdf
*.docx

# ─── OS / editor ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
