# ─── App ───────────────────────────────────────────────────────────────
APP_NAME="NCDC Guideline Chatbot"
ENVIRONMENT=development            # development | production
LOG_LEVEL=INFO
# Public base URL of this API — used to build clickable citation hyperlinks
PUBLIC_BASE_URL=http://localhost:8000

# ─── Security ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
# First admin, created automatically on startup if no users exist
FIRST_ADMIN_EMAIL=admin@ncdc.local
FIRST_ADMIN_PASSWORD=change-me-now

# ─── Relational database (PostgreSQL) ──────────────────────────────────
# Postgres: postgresql+psycopg://user:password@localhost:5432/ncdc_chatbot
# Dev sqlite fallback: sqlite:///./ncdc_chatbot.db
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/ncdc_chatbot

# ─── Qdrant (vector DB) ────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=ncdc_documents
# Per-op timeout (s). Raise for a remote/cloud cluster with high latency so
# wait=True upserts during indexing don't time out.
QDRANT_TIMEOUT=60

# ─── Redis (cache + rate limiting) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
EMBEDDING_CACHE_TTL=604800         # 7 days
RETRIEVAL_CACHE_TTL=3600           # 1 hour
ANSWER_CACHE_TTL=3600              # 1 hour
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30           # /api/chat requests per client IP per minute
# Free messages an anonymous (not-signed-in) visitor may send before they must
# sign in. Counted per client IP over a rolling 24h window (needs Redis to enforce
# server-side; the frontend also gates locally). Set to 0 to require login for chat.
ANON_FREE_MESSAGES=4

# ─── Answer LLM (OpenAI-compatible provider — e.g. Groq) ───────────────
# Any OpenAI-compatible LLM: the `openai` client just targets LLM_BASE_URL, so
# changing provider is config-only. Groq (free key: https://console.groq.com/keys).
# To use Gemini instead: LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# with an aistudio.google.com key and LLM_CHAT_MODEL=gemini-2.5-flash.
LLM_API_KEY=YOUR_LLM_API_KEY_HERE
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_CHAT_MODEL=llama-3.1-8b-instant         # higher quality: llama-3.3-70b-versatile
LLM_REWRITE_MODEL=llama-3.1-8b-instant      # small/fast model for the pre-stream rewrite (blank = reuse chat model)
# Latency guards (seconds): hard cap per LLM call, tighter cap on pre-stream rewrite.
LLM_REQUEST_TIMEOUT=30.0
REWRITE_TIMEOUT=3.0

# ─── Embeddings (small multilingual ONNX bi-encoder via FastEmbed) ─────
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2  # 384-dim
EMBEDDING_DIM=384
EMBED_DEVICE=cpu                   # set to "cuda" if a GPU is available
# Where FastEmbed caches the downloaded ONNX models. The default is the OS temp
# dir, which gets cleaned periodically (Windows Storage Sense, Linux /tmp tmpwatch)
# and can leave a half-deleted model that fails to load. Point it at a PERSISTENT
# path in production. Docker sets this to /app/.cache/fastembed automatically.
FASTEMBED_CACHE_PATH=./.cache/fastembed

# ─── Retrieval tuning (dense search + cross-encoder reranker) ──────────
RETRIEVE_TOP_K=30                  # candidate set fed to the reranker
FINAL_TOP_K=6                      # passages kept and sent to the LLM
# Cross-encoder reranker (CPU, ONNX). Set false to use plain dense order.
RERANKER_ENABLED=true
RERANKER_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# ─── Ingestion / chunking (MVP: single-level fixed-size chunks) ────────
CHUNK_TOKENS=500                   # tokens per chunk (embedded + fed to the LLM)
CHUNK_OVERLAP_TOKENS=60
EMBED_BATCH_SIZE=64                # chunks per embedding batch
UPLOAD_DIR=./storage/documents
MAX_UPLOAD_MB=200

# ─── OCR (scanned / image-only pages) ──────────────────────────────────
# RapidOCR (ONNX on CPU) — no system Tesseract install needed. A page is OCR'd
# only when its text layer has fewer than OCR_MIN_CHARS characters.
OCR_ENABLED=true
OCR_DPI=200                        # render resolution (higher = more accurate, slower)
OCR_MIN_CHARS=80                  # text-layer length below which a page is OCR'd
