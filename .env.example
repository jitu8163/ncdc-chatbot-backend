# ─── App ───────────────────────────────────────────────────────────────
APP_NAME="NCDC Guideline Chatbot"
ENVIRONMENT=development            # development | production
LOG_LEVEL=INFO
# Public base URL of this API — used to build clickable citation hyperlinks
PUBLIC_BASE_URL=http://localhost:8000

# ─── Security ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480
# First admin, created automatically on startup if no users exist
FIRST_ADMIN_EMAIL=admin@ncdc.local
FIRST_ADMIN_PASSWORD=change-me-now

# ─── Relational database (PostgreSQL) ──────────────────────────────────
# Postgres: postgresql+psycopg://user:password@localhost:5432/ncdc_chatbot
# Dev sqlite fallback: sqlite:///./ncdc_chatbot.db
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/ncdc_chatbot

# ─── Qdrant (vector DB) ────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=ncdc_documents

# ─── Redis (cache + rate limiting) ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
EMBEDDING_CACHE_TTL=604800         # 7 days
RETRIEVAL_CACHE_TTL=3600           # 1 hour
ANSWER_CACHE_TTL=3600              # 1 hour
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30           # /api/chat requests per client IP per minute

# ─── Answer LLM (OpenAI-compatible Chat Completions) ───────────────────
# OpenAI:  leave OPENAI_BASE_URL empty, use an OpenAI key + gpt-4o-mini.
# Groq:    set OPENAI_BASE_URL to Groq's endpoint, use a gsk_ key + a Groq model
#          (free, low-latency). Keys: https://console.groq.com/keys
OPENAI_BASE_URL=                   # e.g. https://api.groq.com/openai/v1 for Groq
OPENAI_API_KEY=sk-...              # or gsk_... for Groq
OPENAI_CHAT_MODEL=gpt-4o-mini      # Groq: llama-3.3-70b-versatile | llama-3.1-8b-instant

# ─── Embeddings & reranking (local BAAI models) ────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3        # dense, multilingual, 1024-dim
EMBEDDING_DIM=1024
EMBED_DEVICE=cpu                   # set to "cuda" if a GPU is available
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ─── Retrieval tuning ──────────────────────────────────────────────────
USE_HYBRID_SEARCH=true             # dense (bge-m3) + BM25 sparse, fused with RRF
USE_RERANKER=true
RETRIEVE_TOP_K=40                  # candidates pulled from Qdrant
RERANK_TOP_K=8                     # parent passages kept after reranking
MIN_RERANK_SCORE=0.0               # drop passages below this score (0 = keep all)

# ─── Ingestion / parent-child chunking ─────────────────────────────────
PARENT_CHUNK_TOKENS=1200           # larger context block fed to the LLM
CHILD_CHUNK_TOKENS=350             # small windows that are embedded + searched
CHILD_OVERLAP_TOKENS=60
EMBED_BATCH_SIZE=64                # chunks per embedding batch
UPLOAD_DIR=./storage/documents
MAX_UPLOAD_MB=200
